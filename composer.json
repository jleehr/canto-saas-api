{
  "name": "jleehr/canto-saas-api",
  "type": "library",
  "description": "Client library for Canto SaaS APIs.",
  "homepage": "https://github.com/jleehr/canto-saas-api",
  "license": "MIT",
  "keywords": [
    "Canto",
    "API"
  ],
  "support": {
    "issues": "https://github.com/jleehr/canto-saas-api/issues",
    "source": "https://github.com/jleehr/canto-saas-api"
  },
  "authors": [
    {
      "name": "jleehr",
      "role": "Maintainer",
      "homepage": "https://github.com/jleehr"
    },
    {
      "name": "Tim Schreiner",
      "role": "Developer (original)",
      "email": "tim.schreiner@km2.de"
    },
    {
      "name": "Christian Rodriguez Benthake",
      "role": "Developer (original)",
      "email": "c.rodriguez.benthake@ecentral.de"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.5",
    "psr/log": "^1.1 || ^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.5 || ^12.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpro/grumphp": "^2.5"
  },
  "config": {
    "allow-plugins": {
      "phpro/grumphp": true
    }
  },
  "autoload": {
    "psr-4": {
      "Fairway\\CantoSaasApi\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Fairway\\CantoSaasApi\\Tests\\": "tests"
    }
  }
}
